# --- YouTube Data API (for research + upload) ---
# Get from https://console.cloud.google.com/apis/credentials (enable "YouTube Data API v3")
YOUTUBE_API_KEY=
# OAuth client for uploading (created in same console, type: Desktop App)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Script generation (OpenRouter free tier: https://openrouter.ai) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- Stock visuals (free, https://www.pexels.com/api/) ---
PEXELS_API_KEY=

# --- Meta Graph API (Instagram + Facebook Reels) ---
# https://developers.facebook.com/ -> create app -> Instagram Graph API + Pages API
META_PAGE_ID=
META_IG_USER_ID=
META_ACCESS_TOKEN=

# --- Optional: Telegram notifications on success/failure ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Niche config ---
NICHE_KEYWORDS=space facts,ocean mysteries,psychology facts,history facts
